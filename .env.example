# Copy to .env.local and fill in values
# DO NOT commit .env.local

# Contract address after deployment to Celo mainnet
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Prester judge backend endpoint (existing Gemini endpoint)
# e.g. https://api.presterr.vercel.app/api/roast
ROAST_BACKEND_URL=https://your-prester-backend.vercel.app/api/roast

# Secret key shared between this app and the backend for fulfillRoast
# backend signs the fulfillRoast tx using DEPLOYER_PRIVATE_KEY
ROAST_BACKEND_SECRET=change-me-to-a-random-string

# Optional: for local Celoscan verification during dev
CELOSCAN_API_KEY=
