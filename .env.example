# Copy to .env.local (or .env) and fill in values.
# DO NOT commit any file containing real values.

# ── Public (NEXT_PUBLIC_* — exposed to browser) ──────────────────────

# RoastCourt contract address — filled in after `npm run deploy:mainnet`
NEXT_PUBLIC_ROAST_COURT_ADDRESS=

# cUSD on Celo mainnet (constant; do not change)
NEXT_PUBLIC_CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a

# 42220 = Celo mainnet, 11142220 = Celo Sepolia (testnet)
NEXT_PUBLIC_CHAIN_ID=42220
NEXT_PUBLIC_RPC_URL=https://forno.celo.org

# WalletConnect Cloud project id — desktop / non-MiniPay fallback only
NEXT_PUBLIC_WC_PROJECT_ID=

# Public app URL (used for OG image absolute paths, share links)
NEXT_PUBLIC_APP_URL=https://prester-roast.vercel.app

# ── Server-only (NEVER prefix NEXT_PUBLIC_) ──────────────────────────

# AI judge providers — sequential fallback chain (Groq → Gemini → Anthropic).
# Configure 1, 2, or all 3. Providers without a key are silently skipped, so
# dev environments work with any one of them. With all three set, the roast
# loop survives a full outage of any individual provider.
#
# Groq — primary. Fast, free-tier-generous, native JSON mode.
#   https://console.groq.com/keys
GROQ_API_KEY=
# Gemini — 2nd. Same key Prester uses.
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Anthropic — final fallback. Only fires when both above are down.
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Judge signer — corresponds to the address deployed to the contract.
# Generated by `contracts/scripts/generate-keys.ts`.
# This wallet only authorizes signed verdicts — it never holds or moves funds.
JUDGE_SIGNER_PRIVATE_KEY=

# Pinata IPFS — full verdict payload (roast text + persona + input + ts) goes to IPFS
PINATA_JWT=

# Vercel KV (auto-populated when you enable KV in the Vercel dashboard)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Etherscan v2 API key — used by /api/cron/index for gas-spent backfill.
# Either env var name is accepted (Etherscan v2 unified all chains, May 2025).
ETHERSCAN_API_KEY=
# CELOSCAN_API_KEY= # legacy alias

# Shared secret for the Vercel cron route /api/cron/index. Generate any random string.
CRON_SECRET=

# Optional: starting block for the indexer's first run. If unset, the indexer
# starts ~2000 blocks behind tip. Set this to the deploy block to backfill from
# the very first verdict. Find it on Celoscan under the deploy tx.
INDEXER_FROM_BLOCK=
