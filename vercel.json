{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/index",
      "schedule": "*/1 * * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/index/route.ts": { "maxDuration": 60 }
  }
}
